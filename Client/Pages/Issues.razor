@page "/issues"
@inject HttpClient Http

<PageTitle>Stock Issues</PageTitle>

<h1>Outbound - Stock Issues</h1>

@if (!string.IsNullOrWhiteSpace(serverError))
{
    <div class="alert alert-danger">@serverError</div>
}

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Create Issue</h5>
        <div class="row g-2 mb-2">
            <div class="col-md-4">
                <label class="form-label">Customer</label>
                <InputText class="form-control" @bind-Value="newIssue.Customer" />
            </div>
            <div class="col-md-8">
                <label class="form-label">Note</label>
                <InputText class="form-control" @bind-Value="newIssue.Note" />
            </div>
        </div>

        <div class="row g-2 align-items-end">
            <div class="col-md-7">
                <label class="form-label">Product</label>
                <InputSelect class="form-select" @bind-Value="lineProductId">
                    <option value="0">Select product</option>
                    @foreach (var product in products)
                    {
                        <option value="@product.Id">@product.Sku - @product.Name (On hand: @product.OnHandQty)</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-2">
                <label class="form-label">Qty</label>
                <InputNumber class="form-control" @bind-Value="lineQuantity" />
            </div>
            <div class="col-md-3 d-grid">
                <button class="btn btn-outline-primary" @onclick="AddLine">Add Line</button>
            </div>
        </div>

        @if (newIssue.Lines.Count > 0)
        {
            <table class="table table-sm mt-3">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Qty</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < newIssue.Lines.Count; i++)
                    {
                        var line = newIssue.Lines[i];
                        var lineIndex = i;
                        var product = products.FirstOrDefault(x => x.Id == line.ProductId);
                        <tr>
                            <td>@product?.Name</td>
                            <td>@line.Quantity</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLine(lineIndex)">Remove</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <button class="btn btn-primary" disabled="@isSubmitting" @onclick="SubmitAsync">
                @(isSubmitting ? "Submitting..." : "Submit Issue")
            </button>
        }
    </div>
</div>

@if (isLoading)
{
    <p>Loading issues...</p>
}
else if (issues.Count == 0)
{
    <div class="alert alert-warning">No issues found.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Doc No</th>
                <th>Date</th>
                <th>Customer</th>
                <th>Total</th>
                <th>Lines</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in issues)
            {
                <tr>
                    <td>@item.DocumentNo</td>
                    <td>@item.IssuedAtUtc.ToLocalTime().ToString("g")</td>
                    <td>@item.Customer</td>
                    <td>@item.TotalAmount.ToString("C")</td>
                    <td>@item.LineCount</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" href="/issues/@item.Id">Detail</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool isLoading = true;
    private bool isSubmitting;
    private string? serverError;
    private int lineProductId;
    private int lineQuantity = 1;

    private readonly CreateStockIssueRequest newIssue = new();
    private readonly List<StockIssueListDto> issues = new();
    private readonly List<ProductDto> products = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        serverError = null;
        try
        {
            var issueResult = await Http.GetFromJsonAsync<List<StockIssueListDto>>("api/issues");
            var productResult = await Http.GetFromJsonAsync<List<ProductDto>>("api/products");
            issues.Clear();
            products.Clear();
            if (issueResult is not null)
            {
                issues.AddRange(issueResult);
            }

            if (productResult is not null)
            {
                products.AddRange(productResult.Where(x => x.IsActive));
            }
        }
        catch (Exception ex)
        {
            serverError = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddLine()
    {
        if (lineProductId <= 0 || lineQuantity <= 0)
        {
            serverError = "Please select a product and enter valid quantity.";
            return;
        }

        newIssue.Lines.Add(new CreateStockIssueLineRequest
        {
            ProductId = lineProductId,
            Quantity = lineQuantity
        });

        lineProductId = 0;
        lineQuantity = 1;
        serverError = null;
    }

    private void RemoveLine(int index)
    {
        newIssue.Lines.RemoveAt(index);
    }

    private async Task SubmitAsync()
    {
        if (newIssue.Lines.Count == 0)
        {
            serverError = "Add at least one line before submitting.";
            return;
        }

        isSubmitting = true;
        serverError = null;
        try
        {
            var response = await Http.PostAsJsonAsync("api/issues", newIssue);
            if (!response.IsSuccessStatusCode)
            {
                serverError = await response.Content.ReadAsStringAsync();
                return;
            }

            newIssue.Customer = null;
            newIssue.Note = null;
            newIssue.Lines.Clear();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            serverError = $"Submit failed: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}



