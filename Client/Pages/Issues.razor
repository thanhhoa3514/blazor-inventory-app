@page "/issues"
@attribute [Authorize]
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Stock Issues</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Outbound - Stock Issues</MudText>

@if (!string.IsNullOrWhiteSpace(serverError))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mb-4">
        @serverError
    </MudAlert>
}

<AuthorizeView Roles="@AppRoles.AdminOrWarehouseStaff">
    <Authorized>
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Create Issue</MudText>

            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField T="string" Label="Customer" Variant="Variant.Outlined" @bind-Value="newIssue.Customer" />
                </MudItem>
                <MudItem xs="12" md="8">
                    <MudTextField T="string" Label="Note" Variant="Variant.Outlined" @bind-Value="newIssue.Note" />
                </MudItem>

                <MudItem xs="12" md="7">
                    <MudSelect T="int" Label="Product" Variant="Variant.Outlined" @bind-Value="lineProductId">
                        <MudSelectItem T="int" Value="0">Select product</MudSelectItem>
                        @foreach (var product in products)
                        {
                            <MudSelectItem T="int" Value="@product.Id">@($"{product.Sku} - {product.Name} (On hand: {product.OnHandQty})")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="int" Label="Qty" Min="1" Variant="Variant.Outlined" @bind-Value="lineQuantity" />
                </MudItem>
                <MudItem xs="12" md="3" Class="d-flex align-end">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" OnClick="AddLine">Add Line</MudButton>
                </MudItem>
            </MudGrid>

            @if (newIssue.Lines.Count > 0)
            {
                <MudTable T="CreateStockIssueLineRequest" Items="newIssue.Lines" Hover="true" Dense="true" Class="mt-4">
                    <HeaderContent>
                        <MudTh>Product</MudTh>
                        <MudTh>Qty</MudTh>
                        <MudTh Class="text-right">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="line">
                        <MudTd>@GetProductName(line.ProductId)</MudTd>
                        <MudTd>@line.Quantity</MudTd>
                        <MudTd Class="text-right">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveLine(line))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Class="mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@isSubmitting" OnClick="SubmitAsync">
                        @(isSubmitting ? "Submitting..." : "Submit Issue")
                    </MudButton>
                </MudStack>
            }
        </MudPaper>
    </Authorized>
</AuthorizeView>

<MudTable T="StockIssueListDto" @ref="table" ServerData="LoadServerData" Hover="true" Dense="true" Loading="@isLoading">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Issue History</MudText>
        <MudSpacer />
        <MudTextField T="string"
                      Label="Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Value="@searchTerm"
                      ValueChanged="OnSearchChanged" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="StockIssueListDto" SortLabel="doc">Doc No</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockIssueListDto" SortLabel="date">Date</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockIssueListDto" SortLabel="customer">Customer</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockIssueListDto" SortLabel="total">Total</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockIssueListDto" SortLabel="lines">Lines</MudTableSortLabel></MudTh>
        <MudTh Class="text-right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Doc No">@context.DocumentNo</MudTd>
        <MudTd DataLabel="Date">@context.IssuedAtUtc.ToLocalTime().ToString("g")</MudTd>
        <MudTd DataLabel="Customer">@context.Customer</MudTd>
        <MudTd DataLabel="Total">@context.TotalAmount.ToString("C")</MudTd>
        <MudTd DataLabel="Lines">@context.LineCount</MudTd>
        <MudTd DataLabel="Actions" Class="text-right">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" Href="@($"/issues/{context.Id}")">Detail</MudButton>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="pa-2">No issues found.</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new[] { 5, 10, 25, 50 }" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<StockIssueListDto>? table;
    private bool isLoading = true;
    private bool isSubmitting;
    private string? serverError;
    private string searchTerm = string.Empty;

    private int lineProductId;
    private int lineQuantity = 1;

    private readonly CreateStockIssueRequest newIssue = new();
    private readonly List<StockIssueListDto> issues = new();
    private readonly List<ProductDto> products = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        serverError = null;

        try
        {
            var issueResult = await Http.GetFromJsonAsync<List<StockIssueListDto>>("api/issues");
            var productResult = await Http.GetFromJsonAsync<List<ProductDto>>("api/products");

            issues.Clear();
            products.Clear();

            if (issueResult is not null)
            {
                issues.AddRange(issueResult);
            }

            if (productResult is not null)
            {
                products.AddRange(productResult.Where(x => x.IsActive));
            }
        }
        catch (Exception ex)
        {
            serverError = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            if (table is not null)
            {
                await table.ReloadServerData();
            }
        }
    }

    private void AddLine()
    {
        if (lineProductId <= 0 || lineQuantity <= 0)
        {
            serverError = "Please select a product and enter valid quantity.";
            return;
        }

        newIssue.Lines.Add(new CreateStockIssueLineRequest
        {
            ProductId = lineProductId,
            Quantity = lineQuantity
        });

        lineProductId = 0;
        lineQuantity = 1;
        serverError = null;
    }

    private void RemoveLine(CreateStockIssueLineRequest line)
    {
        newIssue.Lines.Remove(line);
    }

    private async Task SubmitAsync()
    {
        if (newIssue.Lines.Count == 0)
        {
            serverError = "Add at least one line before submitting.";
            return;
        }

        var confirmed = await ConfirmAsync(
            title: "Submit Issue",
            content: $"Submit issue with {newIssue.Lines.Count} line(s)?",
            buttonText: "Submit",
            color: Color.Primary);

        if (!confirmed)
        {
            return;
        }

        isSubmitting = true;
        serverError = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/issues", newIssue);
            if (!response.IsSuccessStatusCode)
            {
                serverError = NormalizeServerError(await response.Content.ReadAsStringAsync());
                return;
            }

            newIssue.Customer = null;
            newIssue.Note = null;
            newIssue.Lines.Clear();

            Snackbar.Add("Issue submitted successfully.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            serverError = $"Submit failed: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task<TableData<StockIssueListDto>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        await Task.Yield();

        IEnumerable<StockIssueListDto> query = issues;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var keyword = searchTerm.Trim();
            query = query.Where(x =>
                x.DocumentNo.Contains(keyword, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(x.Customer) && x.Customer.Contains(keyword, StringComparison.OrdinalIgnoreCase)));
        }

        query = state.SortLabel switch
        {
            "doc" => ApplySort(query, state.SortDirection, x => x.DocumentNo),
            "date" => ApplySort(query, state.SortDirection, x => x.IssuedAtUtc),
            "customer" => ApplySort(query, state.SortDirection, x => x.Customer),
            "total" => ApplySort(query, state.SortDirection, x => x.TotalAmount),
            "lines" => ApplySort(query, state.SortDirection, x => x.LineCount),
            _ => query.OrderByDescending(x => x.IssuedAtUtc)
        };

        var totalItems = query.Count();
        var pagedItems = query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToList();

        return new TableData<StockIssueListDto>
        {
            TotalItems = totalItems,
            Items = pagedItems
        };
    }

    private static IEnumerable<StockIssueListDto> ApplySort<TKey>(IEnumerable<StockIssueListDto> query, SortDirection direction, Func<StockIssueListDto, TKey> keySelector)
        => direction == SortDirection.Descending ? query.OrderByDescending(keySelector) : query.OrderBy(keySelector);

    private async Task OnSearchChanged(string value)
    {
        searchTerm = value;
        if (table is not null)
        {
            await table.ReloadServerData();
        }
    }

    private string GetProductName(int productId)
    {
        var product = products.FirstOrDefault(x => x.Id == productId);
        return product is null ? $"Product #{productId}" : $"{product.Sku} - {product.Name}";
    }

    private async Task<bool> ConfirmAsync(string title, string content, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.ContentText)] = content,
            [nameof(ConfirmDialog.ButtonText)] = buttonText,
            [nameof(ConfirmDialog.Color)] = color
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(title, parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            CloseOnEscapeKey = true,
            FullWidth = true
        });

        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }

    private static string NormalizeServerError(string raw)
        => string.IsNullOrWhiteSpace(raw) ? "Request failed." : raw.Trim().Trim('"');
}
