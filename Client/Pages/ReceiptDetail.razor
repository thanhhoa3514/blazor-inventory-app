@page "/receipts/{Id:int}"
@attribute [Authorize]
@using MudBlazor
@inject HttpClient Http

<PageTitle>Receipt Detail</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Receipt Detail</MudText>

@if (isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">@error</MudAlert>
}
else if (item is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true">Receipt not found.</MudAlert>
}
else
{
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" md="6"><MudText><b>Document:</b> @item.DocumentNo</MudText></MudItem>
            <MudItem xs="12" md="6"><MudText><b>Date:</b> @item.ReceivedAtUtc.ToLocalTime().ToString("g")</MudText></MudItem>
            <MudItem xs="12" md="6"><MudText><b>Supplier:</b> @item.Supplier</MudText></MudItem>
            <MudItem xs="12" md="6"><MudText><b>Total:</b> @item.TotalAmount.ToString("C")</MudText></MudItem>
            <MudItem xs="12"><MudText><b>Note:</b> @item.Note</MudText></MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable T="StockReceiptDetailLineDto" Items="item.Lines" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>SKU</MudTh>
            <MudTh>Product</MudTh>
            <MudTh>Qty</MudTh>
            <MudTh>Unit Cost</MudTh>
            <MudTh>Line Total</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ProductSku</MudTd>
            <MudTd>@context.ProductName</MudTd>
            <MudTd>@context.Quantity</MudTd>
            <MudTd>@context.UnitCost.ToString("C")</MudTd>
            <MudTd>@context.LineTotal.ToString("C")</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool isLoading = true;
    private string? error;
    private StockReceiptDetailDto? item;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        error = null;
        try
        {
            var response = await Http.GetAsync($"api/receipts/{Id}");
            if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                item = null;
                return;
            }

            response.EnsureSuccessStatusCode();
            item = await response.Content.ReadFromJsonAsync<StockReceiptDetailDto>();
        }
        catch (Exception ex)
        {
            error = $"Failed to load receipt: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
