@page "/receipts"
@attribute [Authorize]
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Stock Receipts</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Inbound - Stock Receipts</MudText>

@if (!string.IsNullOrWhiteSpace(serverError))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mb-4">
        @serverError
    </MudAlert>
}

<AuthorizeView Roles="@AppRoles.AdminOrWarehouseStaff">
    <Authorized>
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Create Receipt</MudText>

            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField T="string" Label="Supplier" Variant="Variant.Outlined" @bind-Value="newReceipt.Supplier" />
                </MudItem>
                <MudItem xs="12" md="8">
                    <MudTextField T="string" Label="Note" Variant="Variant.Outlined" @bind-Value="newReceipt.Note" />
                </MudItem>

                <MudItem xs="12" md="5">
                    <MudSelect T="int" Label="Product" Variant="Variant.Outlined" @bind-Value="lineProductId">
                        <MudSelectItem T="int" Value="0">Select product</MudSelectItem>
                        @foreach (var product in products)
                        {
                            <MudSelectItem T="int" Value="@product.Id">@($"{product.Sku} - {product.Name}")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="int" Label="Qty" Min="1" Variant="Variant.Outlined" @bind-Value="lineQuantity" />
                </MudItem>
                <MudItem xs="6" md="2">
                    <MudNumericField T="decimal" Label="Unit Cost" Min="0" Variant="Variant.Outlined" @bind-Value="lineUnitCost" />
                </MudItem>
                <MudItem xs="12" md="3" Class="d-flex align-end">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" OnClick="AddLine">Add Line</MudButton>
                </MudItem>
            </MudGrid>

            @if (newReceipt.Lines.Count > 0)
            {
                <MudTable T="CreateStockReceiptLineRequest" Items="newReceipt.Lines" Hover="true" Dense="true" Class="mt-4">
                    <HeaderContent>
                        <MudTh>Product</MudTh>
                        <MudTh>Qty</MudTh>
                        <MudTh>Unit Cost</MudTh>
                        <MudTh>Total</MudTh>
                        <MudTh Class="text-right">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="line">
                        <MudTd>@GetProductName(line.ProductId)</MudTd>
                        <MudTd>@line.Quantity</MudTd>
                        <MudTd>@line.UnitCost.ToString("C")</MudTd>
                        <MudTd>@(line.Quantity * line.UnitCost).ToString("C")</MudTd>
                        <MudTd Class="text-right">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveLine(line))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3">
                    <MudText Typo="Typo.subtitle1">Total: @CurrentTotal.ToString("C")</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@isSubmitting" OnClick="SubmitAsync">
                        @(isSubmitting ? "Submitting..." : "Submit Receipt")
                    </MudButton>
                </MudStack>
            }
        </MudPaper>
    </Authorized>
</AuthorizeView>

<MudTable T="StockReceiptListDto" @ref="table" ServerData="LoadServerData" Hover="true" Dense="true" Loading="@isLoading">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Receipt History</MudText>
        <MudSpacer />
        <MudTextField T="string"
                      Label="Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Value="@searchTerm"
                      ValueChanged="OnSearchChanged" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="StockReceiptListDto" SortLabel="doc">Doc No</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockReceiptListDto" SortLabel="date">Date</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockReceiptListDto" SortLabel="supplier">Supplier</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockReceiptListDto" SortLabel="total">Total</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockReceiptListDto" SortLabel="lines">Lines</MudTableSortLabel></MudTh>
        <MudTh Class="text-right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Doc No">@context.DocumentNo</MudTd>
        <MudTd DataLabel="Date">@context.ReceivedAtUtc.ToLocalTime().ToString("g")</MudTd>
        <MudTd DataLabel="Supplier">@context.Supplier</MudTd>
        <MudTd DataLabel="Total">@context.TotalAmount.ToString("C")</MudTd>
        <MudTd DataLabel="Lines">@context.LineCount</MudTd>
        <MudTd DataLabel="Actions" Class="text-right">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" Href="@($"/receipts/{context.Id}")">Detail</MudButton>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="pa-2">No receipts found.</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new[] { 5, 10, 25, 50 }" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<StockReceiptListDto>? table;
    private bool isLoading = true;
    private bool isSubmitting;
    private string? serverError;
    private string searchTerm = string.Empty;

    private int lineProductId;
    private int lineQuantity = 1;
    private decimal lineUnitCost = 1m;

    private readonly CreateStockReceiptRequest newReceipt = new();
    private readonly List<StockReceiptListDto> receipts = new();
    private readonly List<ProductDto> products = new();

    private decimal CurrentTotal => newReceipt.Lines.Sum(x => x.Quantity * x.UnitCost);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        serverError = null;

        try
        {
            var receiptResult = await Http.GetFromJsonAsync<List<StockReceiptListDto>>("api/receipts");
            var productResult = await Http.GetFromJsonAsync<List<ProductDto>>("api/products");

            receipts.Clear();
            products.Clear();

            if (receiptResult is not null)
            {
                receipts.AddRange(receiptResult);
            }

            if (productResult is not null)
            {
                products.AddRange(productResult.Where(x => x.IsActive));
            }
        }
        catch (Exception ex)
        {
            serverError = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            if (table is not null)
            {
                await table.ReloadServerData();
            }
        }
    }

    private void AddLine()
    {
        if (lineProductId <= 0 || lineQuantity <= 0 || lineUnitCost < 0)
        {
            serverError = "Please select a product and enter valid quantity and unit cost.";
            return;
        }

        newReceipt.Lines.Add(new CreateStockReceiptLineRequest
        {
            ProductId = lineProductId,
            Quantity = lineQuantity,
            UnitCost = lineUnitCost
        });

        lineProductId = 0;
        lineQuantity = 1;
        lineUnitCost = 1m;
        serverError = null;
    }

    private void RemoveLine(CreateStockReceiptLineRequest line)
    {
        newReceipt.Lines.Remove(line);
    }

    private async Task SubmitAsync()
    {
        if (newReceipt.Lines.Count == 0)
        {
            serverError = "Add at least one line before submitting.";
            return;
        }

        var confirmed = await ConfirmAsync(
            title: "Submit Receipt",
            content: $"Submit receipt with {newReceipt.Lines.Count} line(s) and total {CurrentTotal:C}?",
            buttonText: "Submit",
            color: Color.Primary);

        if (!confirmed)
        {
            return;
        }

        isSubmitting = true;
        serverError = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/receipts", newReceipt);
            if (!response.IsSuccessStatusCode)
            {
                serverError = NormalizeServerError(await response.Content.ReadAsStringAsync());
                return;
            }

            newReceipt.Supplier = null;
            newReceipt.Note = null;
            newReceipt.Lines.Clear();

            Snackbar.Add("Receipt submitted successfully.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            serverError = $"Submit failed: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task<TableData<StockReceiptListDto>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        await Task.Yield();

        IEnumerable<StockReceiptListDto> query = receipts;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var keyword = searchTerm.Trim();
            query = query.Where(x =>
                x.DocumentNo.Contains(keyword, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(x.Supplier) && x.Supplier.Contains(keyword, StringComparison.OrdinalIgnoreCase)));
        }

        query = state.SortLabel switch
        {
            "doc" => ApplySort(query, state.SortDirection, x => x.DocumentNo),
            "date" => ApplySort(query, state.SortDirection, x => x.ReceivedAtUtc),
            "supplier" => ApplySort(query, state.SortDirection, x => x.Supplier),
            "total" => ApplySort(query, state.SortDirection, x => x.TotalAmount),
            "lines" => ApplySort(query, state.SortDirection, x => x.LineCount),
            _ => query.OrderByDescending(x => x.ReceivedAtUtc)
        };

        var totalItems = query.Count();
        var pagedItems = query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToList();

        return new TableData<StockReceiptListDto>
        {
            TotalItems = totalItems,
            Items = pagedItems
        };
    }

    private static IEnumerable<StockReceiptListDto> ApplySort<TKey>(IEnumerable<StockReceiptListDto> query, SortDirection direction, Func<StockReceiptListDto, TKey> keySelector)
        => direction == SortDirection.Descending ? query.OrderByDescending(keySelector) : query.OrderBy(keySelector);

    private async Task OnSearchChanged(string value)
    {
        searchTerm = value;
        if (table is not null)
        {
            await table.ReloadServerData();
        }
    }

    private string GetProductName(int productId)
    {
        var product = products.FirstOrDefault(x => x.Id == productId);
        return product is null ? $"Product #{productId}" : $"{product.Sku} - {product.Name}";
    }

    private async Task<bool> ConfirmAsync(string title, string content, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.ContentText)] = content,
            [nameof(ConfirmDialog.ButtonText)] = buttonText,
            [nameof(ConfirmDialog.Color)] = color
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(title, parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            CloseOnEscapeKey = true,
            FullWidth = true
        });

        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }

    private static string NormalizeServerError(string raw)
        => string.IsNullOrWhiteSpace(raw) ? "Request failed." : raw.Trim().Trim('"');
}
