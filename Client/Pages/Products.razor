@page "/products"
@attribute [Authorize]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Products</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Products</MudText>

@if (!string.IsNullOrWhiteSpace(serverError))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mb-4">
        @serverError
    </MudAlert>
}

<AuthorizeView Roles="@AppRoles.Admin">
    <Authorized>
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudForm @ref="formRef" Model="@form">
                <MudGrid>
                    <MudItem xs="12" md="2">
                        <MudTextField T="string" Label="SKU" Variant="Variant.Outlined" @bind-Value="form.Sku"
                                      For="@(() => form.Sku)" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField T="string" Label="Name" Variant="Variant.Outlined" @bind-Value="form.Name"
                                      For="@(() => form.Name)" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField T="string" Label="Description" Variant="Variant.Outlined" @bind-Value="form.Description"
                                      For="@(() => form.Description)" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudSelect T="int" Label="Category" Variant="Variant.Outlined" @bind-Value="form.CategoryId"
                                   For="@(() => form.CategoryId)">
                            <MudSelectItem T="int" Value="0">Select category</MudSelectItem>
                            @foreach (var category in categories)
                            {
                                <MudSelectItem T="int" Value="@category.Id">@category.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" md="1">
                        <MudNumericField T="int" Label="Reorder" Variant="Variant.Outlined" Min="0"
                                         @bind-Value="form.ReorderLevel" For="@(() => form.ReorderLevel)" />
                    </MudItem>
                    <MudItem xs="6" md="1" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="@isSubmitting"
                                   OnClick="SaveAsync">
                            @(isSubmitting ? "..." : (editingId.HasValue ? "Update" : "Create"))
                        </MudButton>
                    </MudItem>
                    @if (editingId.HasValue)
                    {
                        <MudItem xs="12">
                            <MudSwitch T="bool" Color="Color.Primary" @bind-Value="form.IsActive">Active product</MudSwitch>
                        </MudItem>
                    }
                </MudGrid>
            </MudForm>
        </MudPaper>
    </Authorized>
</AuthorizeView>

<MudTable T="ProductDto" @ref="table" ServerData="LoadServerData" Hover="true" Dense="true" Loading="@isLoading">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Product List</MudText>
        <MudSpacer />
        <MudTextField T="string" Label="Search" Variant="Variant.Outlined" Margin="Margin.Dense"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Value="@searchTerm"
                      ValueChanged="OnSearchChanged" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel T="ProductDto" SortLabel="sku">SKU</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel T="ProductDto" SortLabel="name">Name</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel T="ProductDto" SortLabel="category">Category</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel T="ProductDto" SortLabel="onhand">On Hand</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel T="ProductDto" SortLabel="avgcost">Avg Cost</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel T="ProductDto" SortLabel="reorder">Reorder</MudTableSortLabel>
        </MudTh>
        <MudTh>Status</MudTh>
        <MudTh Class="text-right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="SKU">@context.Sku</MudTd>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Category">@context.CategoryName</MudTd>
        <MudTd DataLabel="On Hand">@context.OnHandQty</MudTd>
        <MudTd DataLabel="Avg Cost">@context.AverageCost.ToString("C")</MudTd>
        <MudTd DataLabel="Reorder">@context.ReorderLevel</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive? Color.Success: Color.Default)">
                @(context.IsActive ? "Active" : "Inactive")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Actions" Class="text-right">
            <AuthorizeView Roles="@AppRoles.Admin">
                <Authorized Context="authState">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                               OnClick="@(() => StartEdit(context))">Edit</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" Class="ml-2"
                               OnClick="@(() => DeleteAsync(context))">Delete</MudButton>
                </Authorized>
            </AuthorizeView>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="pa-2">No products found.</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new[] { 5, 10, 25, 50 }" />
    </PagerContent>
</MudTable>

@code {
    private class ProductForm : CreateProductRequest
    {
        public bool IsActive { get; set; } = true;
    }

    private readonly ProductForm form = new();
    private readonly List<ProductDto> items = new();
    private readonly List<CategoryDto> categories = new();

    private MudForm? formRef;
    private MudTable<ProductDto>? table;
    private int? editingId;
    private bool isLoading = true;
    private bool isSubmitting;
    private string? serverError;
    private string searchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        serverError = null;
        var errors = new List<string>();
        List<CategoryDto>? categoryResult = null;
        List<ProductDto>? productResult = null;

        try
        {
            categoryResult = await Http.GetFromJsonAsync<List<CategoryDto>>("api/categories");
        }
        catch (Exception ex)
        {
            errors.Add($"categories: {ex.Message}");
        }

        try
        {
            productResult = await Http.GetFromJsonAsync<List<ProductDto>>("api/products");
        }
        catch (Exception ex)
        {
            errors.Add($"products: {ex.Message}");
        }

        categories.Clear();
        items.Clear();

        if (categoryResult is not null)
        {
            categories.AddRange(categoryResult);
        }

        if (productResult is not null)
        {
            items.AddRange(productResult);
        }

        if (errors.Count > 0)
        {
            serverError = $"Failed to load data ({string.Join(" | ", errors)})";
        }

        try
        {
            isLoading = false;
            if (table is not null)
            {
                await table.ReloadServerData();
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (formRef is null)
        {
            return;
        }

        await formRef.Validate();
        if (!formRef.IsValid)
        {
            return;
        }

        isSubmitting = true;
        serverError = null;
        try
        {
            HttpResponseMessage response;
            if (editingId.HasValue)
            {
                response = await Http.PutAsJsonAsync($"api/products/{editingId.Value}", new UpdateProductRequest
                {
                    Sku = form.Sku,
                    Name = form.Name,
                    Description = form.Description,
                    CategoryId = form.CategoryId,
                    ReorderLevel = form.ReorderLevel,
                    IsActive = form.IsActive
                });
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/products", new CreateProductRequest
                {
                    Sku = form.Sku,
                    Name = form.Name,
                    Description = form.Description,
                    CategoryId = form.CategoryId,
                    ReorderLevel = form.ReorderLevel
                });
            }

            if (!response.IsSuccessStatusCode)
            {
                serverError = NormalizeServerError(await response.Content.ReadAsStringAsync());
                return;
            }

            Snackbar.Add(editingId.HasValue ? "Product updated." : "Product created.", Severity.Success);
            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            serverError = $"Save failed: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void StartEdit(ProductDto item)
    {
        editingId = item.Id;
        form.Sku = item.Sku;
        form.Name = item.Name;
        form.Description = item.Description;
        form.CategoryId = item.CategoryId;
        form.ReorderLevel = item.ReorderLevel;
        form.IsActive = item.IsActive;
    }

    private async Task DeleteAsync(ProductDto item)
    {
        serverError = null;

        var confirmed = await ConfirmAsync(
            title: "Delete Product",
            content: $"Delete product '{item.Sku} - {item.Name}'? This action cannot be undone.",
            buttonText: "Delete",
            color: Color.Error);

        if (!confirmed)
        {
            return;
        }

        try
        {
            var response = await Http.DeleteAsync($"api/products/{item.Id}");
            if (!response.IsSuccessStatusCode)
            {
                serverError = NormalizeServerError(await response.Content.ReadAsStringAsync());
                return;
            }

            if (editingId == item.Id)
            {
                ResetForm();
            }

            Snackbar.Add("Product deleted.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            serverError = $"Delete failed: {ex.Message}";
        }
    }

    private async Task<TableData<ProductDto>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        await Task.Yield();

        IEnumerable<ProductDto> query = items;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var keyword = searchTerm.Trim();
            query = query.Where(x =>
                x.Sku.Contains(keyword, StringComparison.OrdinalIgnoreCase) ||
                x.Name.Contains(keyword, StringComparison.OrdinalIgnoreCase) ||
                x.CategoryName.Contains(keyword, StringComparison.OrdinalIgnoreCase));
        }

        query = state.SortLabel switch
        {
            "sku" => ApplySort(query, state.SortDirection, x => x.Sku),
            "name" => ApplySort(query, state.SortDirection, x => x.Name),
            "category" => ApplySort(query, state.SortDirection, x => x.CategoryName),
            "onhand" => ApplySort(query, state.SortDirection, x => x.OnHandQty),
            "avgcost" => ApplySort(query, state.SortDirection, x => x.AverageCost),
            "reorder" => ApplySort(query, state.SortDirection, x => x.ReorderLevel),
            _ => query.OrderBy(x => x.Name)
        };

        var totalItems = query.Count();
        var pagedItems = query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToList();

        return new TableData<ProductDto>
        {
            TotalItems = totalItems,
            Items = pagedItems
        };
    }

    private static IEnumerable<ProductDto> ApplySort<TKey>(IEnumerable<ProductDto> query, SortDirection direction,
Func<ProductDto, TKey> keySelector)
        => direction == SortDirection.Descending ? query.OrderByDescending(keySelector) : query.OrderBy(keySelector);

    private async Task OnSearchChanged(string value)
    {
        searchTerm = value;
        if (table is not null)
        {
            await table.ReloadServerData();
        }
    }

    private async Task<bool> ConfirmAsync(string title, string content, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.ContentText)] = content,
            [nameof(ConfirmDialog.ButtonText)] = buttonText,
            [nameof(ConfirmDialog.Color)] = color
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(title, parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            CloseOnEscapeKey = true,
            FullWidth = true
        });

        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }

    private void ResetForm()
    {
        editingId = null;
        form.Sku = string.Empty;
        form.Name = string.Empty;
        form.Description = null;
        form.CategoryId = 0;
        form.ReorderLevel = 5;
        form.IsActive = true;
    }

    private static string NormalizeServerError(string raw)
        => string.IsNullOrWhiteSpace(raw) ? "Request failed." : raw.Trim().Trim('"');
}
