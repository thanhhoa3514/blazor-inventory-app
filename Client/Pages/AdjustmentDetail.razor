@page "/adjustments/{Id:int}"
@attribute [Authorize]
@using MudBlazor
@inject HttpClient Http

<PageTitle>Adjustment Detail</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Adjustment Detail</MudText>

@if (isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">@error</MudAlert>
}
else if (item is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true">Adjustment not found.</MudAlert>
}
else
{
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" md="6"><MudText><b>Document:</b> @item.DocumentNo</MudText></MudItem>
            <MudItem xs="12" md="6"><MudText><b>Date:</b> @item.AdjustedAtUtc.ToLocalTime().ToString("g")</MudText></MudItem>
            <MudItem xs="12" md="6"><MudText><b>Reason:</b> @item.Reason</MudText></MudItem>
            <MudItem xs="12" md="6"><MudText><b>Net Value:</b> @item.TotalAmount.ToString("C")</MudText></MudItem>
            <MudItem xs="12"><MudText><b>Note:</b> @item.Note</MudText></MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable T="StockAdjustmentDetailLineDto" Items="item.Lines" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>SKU</MudTh>
            <MudTh>Product</MudTh>
            <MudTh>Direction</MudTh>
            <MudTh>Qty</MudTh>
            <MudTh>Unit Cost</MudTh>
            <MudTh>Line Total</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ProductSku</MudTd>
            <MudTd>@context.ProductName</MudTd>
            <MudTd>@GetDirectionLabel(context.Direction)</MudTd>
            <MudTd>@GetSignedQuantity(context)</MudTd>
            <MudTd>@context.UnitCost.ToString("C")</MudTd>
            <MudTd>@context.LineTotal.ToString("C")</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool isLoading = true;
    private string? error;
    private StockAdjustmentDetailDto? item;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        error = null;
        try
        {
            var response = await Http.GetAsync($"api/adjustments/{Id}");
            if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                item = null;
                return;
            }

            response.EnsureSuccessStatusCode();
            item = await response.Content.ReadFromJsonAsync<StockAdjustmentDetailDto>();
        }
        catch (Exception ex)
        {
            error = $"Failed to load adjustment: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static int GetSignedQuantity(StockAdjustmentDetailLineDto line)
        => string.Equals(line.Direction, StockAdjustmentDirections.Decrease, StringComparison.OrdinalIgnoreCase)
            ? -line.Quantity
            : line.Quantity;

    private static string GetDirectionLabel(string direction)
        => string.Equals(direction, StockAdjustmentDirections.Decrease, StringComparison.OrdinalIgnoreCase) ? "Decrease" : "Increase";
}
