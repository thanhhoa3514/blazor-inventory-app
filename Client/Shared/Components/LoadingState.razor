@namespace MyApp.Client.Shared.Components

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="@Class">
    <MudProgressCircular Color="@Color" Indeterminate="true" Size="@Size" />
    <MudText Typo="Typo.body2">@Message</MudText>
</MudStack>

@code {
    [Parameter] public string Message { get; set; } = "Loading...";
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public Size Size { get; set; } = Size.Medium;
    [Parameter] public string? Class { get; set; }
}
