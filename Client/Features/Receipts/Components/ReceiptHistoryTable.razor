@namespace MyApp.Client.Features.Receipts.Components

<MudTable T="StockReceiptListDto" @key="ReloadKey" @ref="_table" ServerData="LoadServerDataAsync" Hover="true" Dense="true" Loading="@IsLoading">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Receipt History</MudText>
        <MudSpacer />
        <MudTextField T="string"
                      Label="Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Value="@SearchTerm"
                      ValueChanged="OnSearchChangedAsync" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="StockReceiptListDto" SortLabel="doc">Doc No</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockReceiptListDto" SortLabel="date">Date</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockReceiptListDto" SortLabel="supplier">Supplier</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockReceiptListDto" SortLabel="total">Total</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="StockReceiptListDto" SortLabel="lines">Lines</MudTableSortLabel></MudTh>
        <MudTh Class="text-right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Doc No">@context.DocumentNo</MudTd>
        <MudTd DataLabel="Date">@context.ReceivedAtUtc.ToLocalTime().ToString("g")</MudTd>
        <MudTd DataLabel="Supplier">@context.Supplier</MudTd>
        <MudTd DataLabel="Total">@context.TotalAmount.ToString("C")</MudTd>
        <MudTd DataLabel="Lines">@context.LineCount</MudTd>
        <MudTd DataLabel="Actions" Class="text-right">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" Href="@($"/receipts/{context.Id}")">Detail</MudButton>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="pa-2">No receipts found.</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new[] { 5, 10, 25, 50 }" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<StockReceiptListDto>? _table;

    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string SearchTerm { get; set; } = string.Empty;
    [Parameter] public int ReloadKey { get; set; }
    [Parameter] public EventCallback<string> SearchTermChanged { get; set; }
    [Parameter, EditorRequired] public Func<TableState, CancellationToken, Task<TableData<StockReceiptListDto>>> ServerData { get; set; } = default!;

    private Task<TableData<StockReceiptListDto>> LoadServerDataAsync(TableState state, CancellationToken cancellationToken)
        => ServerData.Invoke(state, cancellationToken);

    private async Task OnSearchChangedAsync(string value)
    {
        await SearchTermChanged.InvokeAsync(value);
        if (_table is not null)
        {
            await _table.ReloadServerData();
        }
    }
}
