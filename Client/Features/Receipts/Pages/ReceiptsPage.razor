@page "/receipts"
@attribute [Authorize]
@inject ReceiptApiClient ReceiptApiClient
@inject ProductApiClient ProductApiClient
@inject SupplierApiClient SupplierApiClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Stock Receipts</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Inbound - Stock Receipts</MudText>

@if (!string.IsNullOrWhiteSpace(_serverError))
{
    <ErrorState Message="@_serverError" Class="mb-4" />
}

<ReceiptEditor Model="_newReceipt"
               Products="_products"
               Suppliers="_suppliers"
               SelectedSupplier="_selectedSupplier"
               SelectedSupplierChanged="OnSupplierChanged"
               SelectedProductId="_lineProductId"
               SelectedProductIdChanged="@(value => _lineProductId = value)"
               Quantity="_lineQuantity"
               QuantityChanged="@(value => _lineQuantity = value)"
               UnitCost="_lineUnitCost"
               UnitCostChanged="@(value => _lineUnitCost = value)"
               IsSubmitting="_isSubmitting"
               OnAddLine="AddLine"
               OnRemoveLine="RemoveLine"
               OnSubmit="SubmitAsync" />

<ReceiptHistoryTable IsLoading="_isLoading"
                     SearchTerm="_searchTerm"
                     FromDate="_fromDate"
                     ToDate="_toDate"
                     ReloadKey="_tableReloadKey"
                     SearchTermChanged="OnSearchChanged"
                     FromDateChanged="OnFromDateChanged"
                     ToDateChanged="OnToDateChanged"
                     ServerData="LoadServerData" />

@code {
    private bool _isLoading = true;
    private bool _isSubmitting;
    private int _tableReloadKey;
    private string? _serverError;
    private string _searchTerm = string.Empty;
    private DateTime? _fromDate;
    private DateTime? _toDate;

    private int _lineProductId;
    private int _lineQuantity = 1;
    private decimal _lineUnitCost = 1m;

    private readonly CreateStockReceiptRequest _newReceipt = new();
    private readonly List<StockReceiptListDto> _receipts = new();
    private readonly List<ProductDto> _products = new();
    private readonly List<SupplierDto> _suppliers = new();
    private SupplierDto? _selectedSupplier;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _serverError = null;

        try
        {
            var receiptResult = await ReceiptApiClient.GetAllAsync();
            var productResult = await ProductApiClient.GetActiveAsync();
            var supplierResult = await SupplierApiClient.GetActiveAsync();

            _receipts.Clear();
            _products.Clear();
            _suppliers.Clear();
            _receipts.AddRange(receiptResult);
            _products.AddRange(productResult);
            _suppliers.AddRange(supplierResult);
        }
        catch (Exception ex)
        {
            _serverError = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            _tableReloadKey++;
        }
    }

    private Task AddLine()
    {
        if (_lineProductId <= 0 || _lineQuantity <= 0 || _lineUnitCost < 0)
        {
            _serverError = "Please select a product and enter valid quantity and unit cost.";
            return Task.CompletedTask;
        }

        _newReceipt.Lines.Add(new CreateStockReceiptLineRequest
        {
            ProductId = _lineProductId,
            Quantity = _lineQuantity,
            UnitCost = _lineUnitCost
        });

        _lineProductId = 0;
        _lineQuantity = 1;
        _lineUnitCost = 1m;
        _serverError = null;
        return Task.CompletedTask;
    }

    private Task RemoveLine(CreateStockReceiptLineRequest line)
    {
        _newReceipt.Lines.Remove(line);
        return Task.CompletedTask;
    }

    private async Task SubmitAsync()
    {
        if (_newReceipt.Lines.Count == 0)
        {
            _serverError = "Add at least one line before submitting.";
            return;
        }

        var confirmed = await ConfirmAsync(
            title: "Submit Receipt",
            content: $"Submit receipt with {_newReceipt.Lines.Count} line(s) and total {_newReceipt.Lines.Sum(x => x.Quantity * x.UnitCost):C}?",
            buttonText: "Submit",
            color: Color.Primary);

        if (!confirmed)
        {
            return;
        }

        _isSubmitting = true;
        _serverError = null;

        try
        {
            var result = await ReceiptApiClient.CreateAsync(_newReceipt);
            if (!result.Success)
            {
                _serverError = result.ErrorMessage;
                return;
            }

            _newReceipt.Note = null;
            _newReceipt.Lines.Clear();
            _newReceipt.SupplierId = null;
            _selectedSupplier = null;

            Snackbar.Add("Receipt submitted successfully.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _serverError = $"Submit failed: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private Task<TableData<StockReceiptListDto>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        IEnumerable<StockReceiptListDto> query = _receipts;

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var keyword = _searchTerm.Trim();
            query = query.Where(x =>
                x.DocumentNo.Contains(keyword, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(x.Supplier) && x.Supplier.Contains(keyword, StringComparison.OrdinalIgnoreCase)));
        }

        if (_fromDate.HasValue)
        {
            var from = _fromDate.Value.Date;
            query = query.Where(x => x.ReceivedAtUtc.ToLocalTime().Date >= from);
        }

        if (_toDate.HasValue)
        {
            var to = _toDate.Value.Date;
            query = query.Where(x => x.ReceivedAtUtc.ToLocalTime().Date <= to);
        }

        query = state.SortLabel switch
        {
            "doc" => ApplySort(query, state.SortDirection, x => x.DocumentNo),
            "date" => ApplySort(query, state.SortDirection, x => x.ReceivedAtUtc),
            "supplier" => ApplySort(query, state.SortDirection, x => x.Supplier),
            "total" => ApplySort(query, state.SortDirection, x => x.TotalAmount),
            "lines" => ApplySort(query, state.SortDirection, x => x.LineCount),
            _ => query.OrderByDescending(x => x.ReceivedAtUtc)
        };

        var totalItems = query.Count();
        var pagedItems = query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToList();

        return Task.FromResult(new TableData<StockReceiptListDto>
        {
            TotalItems = totalItems,
            Items = pagedItems
        });
    }

    private static IEnumerable<StockReceiptListDto> ApplySort<TKey>(IEnumerable<StockReceiptListDto> query, SortDirection direction, Func<StockReceiptListDto, TKey> keySelector)
        => direction == SortDirection.Descending ? query.OrderByDescending(keySelector) : query.OrderBy(keySelector);

    private Task OnSupplierChanged(SupplierDto? supplier)
    {
        _selectedSupplier = supplier;
        _newReceipt.SupplierId = supplier?.Id;
        return Task.CompletedTask;
    }

    private Task OnSearchChanged(string value)
    {
        _searchTerm = value;
        return Task.CompletedTask;
    }

    private Task OnFromDateChanged(DateTime? value)
    {
        _fromDate = value;
        return Task.CompletedTask;
    }

    private Task OnToDateChanged(DateTime? value)
    {
        _toDate = value;
        return Task.CompletedTask;
    }

    private async Task<bool> ConfirmAsync(string title, string content, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.ContentText)] = content,
            [nameof(ConfirmDialog.ButtonText)] = buttonText,
            [nameof(ConfirmDialog.Color)] = color
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(title, parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            CloseOnEscapeKey = true,
            FullWidth = true
        });

        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }
}
