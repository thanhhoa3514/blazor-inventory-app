@namespace MyApp.Client.Features.Inventory.Components

<MudText Typo="Typo.h6" Class="mb-3">Low Stock Items</MudText>

@if (Items.Count == 0)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Dense="true">
        All products are above reorder level.
    </MudAlert>
}
else
{
    <MudTable T="LowStockItemDto" Items="Items" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>SKU</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>On Hand</MudTh>
            <MudTh>Reorder Level</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="SKU">@context.Sku</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Category">@context.CategoryName</MudTd>
            <MudTd DataLabel="On Hand">@context.OnHandQty</MudTd>
            <MudTd DataLabel="Reorder">@context.ReorderLevel</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter] public IReadOnlyList<LowStockItemDto> Items { get; set; } = Array.Empty<LowStockItemDto>();
}
