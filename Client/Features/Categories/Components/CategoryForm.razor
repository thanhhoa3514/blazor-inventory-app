@namespace MyApp.Client.Features.Categories.Components

<AuthorizeView Roles="@AppRoles.Admin">
    <Authorized>
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudForm @ref="_formRef" Model="@Model">
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField T="string" Label="Name" Variant="Variant.Outlined" @bind-Value="Model.Name" For="@(() => Model.Name)" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Description" Variant="Variant.Outlined" @bind-Value="Model.Description" For="@(() => Model.Description)" />
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="@IsSubmitting" OnClick="SubmitAsync">
                            @(IsSubmitting ? "Saving..." : (IsEditing ? "Update" : "Create"))
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudForm>
        </MudPaper>
    </Authorized>
</AuthorizeView>

@code {
    private MudForm? _formRef;

    [Parameter, EditorRequired] public CreateCategoryRequest Model { get; set; } = default!;
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public bool IsEditing { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }

    private async Task SubmitAsync()
    {
        if (_formRef is null)
        {
            return;
        }

        await _formRef.Validate();
        if (_formRef.IsValid)
        {
            await OnSubmit.InvokeAsync();
        }
    }
}
