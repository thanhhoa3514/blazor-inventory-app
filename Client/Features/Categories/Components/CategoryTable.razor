@namespace MyApp.Client.Features.Categories.Components

<MudTable T="CategoryDto" @key="ReloadKey" @ref="_table" ServerData="LoadServerDataAsync" Hover="true" Dense="true" Loading="@IsLoading">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Category List</MudText>
        <MudSpacer />
        <MudTextField T="string"
                      Label="Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Value="@SearchTerm"
                      ValueChanged="OnSearchChangedAsync" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="CategoryDto" SortLabel="name">Name</MudTableSortLabel></MudTh>
        <MudTh>Description</MudTh>
        <MudTh><MudTableSortLabel T="CategoryDto" SortLabel="created">Created</MudTableSortLabel></MudTh>
        <MudTh Class="text-right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Description">@context.Description</MudTd>
        <MudTd DataLabel="Created">@context.CreatedAtUtc.ToLocalTime().ToString("g")</MudTd>
        <MudTd DataLabel="Actions" Class="text-right">
            <AuthorizeView Roles="@AppRoles.Admin">
                <Authorized Context="authState">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" OnClick="@(() => OnEdit.InvokeAsync(context))">Edit</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" Class="ml-2" OnClick="@(() => OnDelete.InvokeAsync(context))">Delete</MudButton>
                </Authorized>
            </AuthorizeView>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="pa-2">No categories found.</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new[] { 5, 10, 25, 50 }" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<CategoryDto>? _table;

    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string SearchTerm { get; set; } = string.Empty;
    [Parameter] public int ReloadKey { get; set; }
    [Parameter] public EventCallback<string> SearchTermChanged { get; set; }
    [Parameter, EditorRequired] public Func<TableState, CancellationToken, Task<TableData<CategoryDto>>> ServerData { get; set; } = default!;
    [Parameter] public EventCallback<CategoryDto> OnEdit { get; set; }
    [Parameter] public EventCallback<CategoryDto> OnDelete { get; set; }

    private Task<TableData<CategoryDto>> LoadServerDataAsync(TableState state, CancellationToken cancellationToken)
        => ServerData.Invoke(state, cancellationToken);

    private async Task OnSearchChangedAsync(string value)
    {
        await SearchTermChanged.InvokeAsync(value);
        if (_table is not null)
        {
            await _table.ReloadServerData();
        }
    }
}
