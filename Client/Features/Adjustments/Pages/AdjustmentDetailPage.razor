@page "/adjustments/{Id:int}"
@attribute [Authorize]
@inject AdjustmentApiClient AdjustmentApiClient

<PageTitle>Adjustment Detail</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Adjustment Detail</MudText>

@if (_isLoading)
{
    <LoadingState Message="Loading adjustment..." />
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <ErrorState Message="@_error" />
}
else if (_item is null)
{
    <ErrorState Message="Adjustment not found." Severity="Severity.Warning" />
}
else
{
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" md="6"><MudText><b>Document:</b> @_item.DocumentNo</MudText></MudItem>
            <MudItem xs="12" md="6"><MudText><b>Date:</b> @_item.AdjustedAtUtc.ToLocalTime().ToString("g")</MudText></MudItem>
            <MudItem xs="12" md="6"><MudText><b>Reason:</b> @_item.Reason</MudText></MudItem>
            <MudItem xs="12" md="6"><MudText><b>Net Value:</b> @_item.TotalAmount.ToString("C")</MudText></MudItem>
            <MudItem xs="12"><MudText><b>Note:</b> @_item.Note</MudText></MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable T="StockAdjustmentDetailLineDto" Items="_item.Lines" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>SKU</MudTh>
            <MudTh>Product</MudTh>
            <MudTh>Direction</MudTh>
            <MudTh>Qty</MudTh>
            <MudTh>Unit Cost</MudTh>
            <MudTh>Line Total</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ProductSku</MudTd>
            <MudTd>@context.ProductName</MudTd>
            <MudTd>@GetDirectionLabel(context.Direction)</MudTd>
            <MudTd>@GetSignedQuantity(context)</MudTd>
            <MudTd>@context.UnitCost.ToString("C")</MudTd>
            <MudTd>@context.LineTotal.ToString("C")</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _isLoading = true;
    private string? _error;
    private StockAdjustmentDetailDto? _item;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            _item = await AdjustmentApiClient.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load adjustment: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static int GetSignedQuantity(StockAdjustmentDetailLineDto line)
        => string.Equals(line.Direction, StockAdjustmentDirections.Decrease, StringComparison.OrdinalIgnoreCase)
            ? -line.Quantity
            : line.Quantity;

    private static string GetDirectionLabel(string direction)
        => string.Equals(direction, StockAdjustmentDirections.Decrease, StringComparison.OrdinalIgnoreCase) ? "Decrease" : "Increase";
}
