@page "/adjustments"
@attribute [Authorize]
@inject AdjustmentApiClient AdjustmentApiClient
@inject ProductApiClient ProductApiClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Stock Adjustments</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Inventory - Stock Adjustments</MudText>

@if (!string.IsNullOrWhiteSpace(_serverError))
{
    <ErrorState Message="@_serverError" Class="mb-4" />
}

<AdjustmentEditor Model="_newAdjustment"
                  Products="_products"
                  SelectedProductId="_lineProductId"
                  SelectedProductIdChanged="@(value => _lineProductId = value)"
                  Direction="_lineDirection"
                  DirectionChanged="@(value => _lineDirection = value)"
                  Quantity="_lineQuantity"
                  QuantityChanged="@(value => _lineQuantity = value)"
                  IsSubmitting="_isSubmitting"
                  OnAddLine="AddLine"
                  OnRemoveLine="RemoveLine"
                  OnSubmit="SubmitAsync" />

<AdjustmentHistoryTable IsLoading="_isLoading"
                        SearchTerm="_searchTerm"
                        SearchTermChanged="OnSearchChanged"
                        ServerData="LoadServerData" />

@code {
    private bool _isLoading = true;
    private bool _isSubmitting;
    private string? _serverError;
    private string _searchTerm = string.Empty;

    private int _lineProductId;
    private string _lineDirection = StockAdjustmentDirections.Increase;
    private int _lineQuantity = 1;

    private readonly CreateStockAdjustmentRequest _newAdjustment = new();
    private readonly List<StockAdjustmentListDto> _adjustments = new();
    private readonly List<ProductDto> _products = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _serverError = null;

        try
        {
            var adjustmentResult = await AdjustmentApiClient.GetAllAsync();
            var productResult = await ProductApiClient.GetActiveAsync();

            _adjustments.Clear();
            _products.Clear();
            _adjustments.AddRange(adjustmentResult);
            _products.AddRange(productResult);
        }
        catch (Exception ex)
        {
            _serverError = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task AddLine()
    {
        if (string.IsNullOrWhiteSpace(_newAdjustment.Reason))
        {
            _serverError = "Reason is required before adding lines.";
            return Task.CompletedTask;
        }

        if (_lineProductId <= 0 || _lineQuantity <= 0 || !IsValidDirection(_lineDirection))
        {
            _serverError = "Please select a product, direction, and valid quantity.";
            return Task.CompletedTask;
        }

        _newAdjustment.Lines.Add(new CreateStockAdjustmentLineRequest
        {
            ProductId = _lineProductId,
            Direction = _lineDirection,
            Quantity = _lineQuantity
        });

        _lineProductId = 0;
        _lineDirection = StockAdjustmentDirections.Increase;
        _lineQuantity = 1;
        _serverError = null;
        return Task.CompletedTask;
    }

    private Task RemoveLine(CreateStockAdjustmentLineRequest line)
    {
        _newAdjustment.Lines.Remove(line);
        return Task.CompletedTask;
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_newAdjustment.Reason))
        {
            _serverError = "Reason is required.";
            return;
        }

        if (_newAdjustment.Lines.Count == 0)
        {
            _serverError = "Add at least one line before submitting.";
            return;
        }

        var confirmed = await ConfirmAsync(
            title: "Submit Adjustment",
            content: $"Submit adjustment with {_newAdjustment.Lines.Count} line(s) for reason '{_newAdjustment.Reason}'?",
            buttonText: "Submit",
            color: Color.Primary);

        if (!confirmed)
        {
            return;
        }

        _isSubmitting = true;
        _serverError = null;

        try
        {
            var result = await AdjustmentApiClient.CreateAsync(_newAdjustment);
            if (!result.Success)
            {
                _serverError = result.ErrorMessage;
                return;
            }

            _newAdjustment.Reason = string.Empty;
            _newAdjustment.Note = null;
            _newAdjustment.Lines.Clear();
            _lineDirection = StockAdjustmentDirections.Increase;

            Snackbar.Add("Adjustment submitted successfully.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _serverError = $"Submit failed: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private Task<TableData<StockAdjustmentListDto>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        IEnumerable<StockAdjustmentListDto> query = _adjustments;

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var keyword = _searchTerm.Trim();
            query = query.Where(x =>
                x.DocumentNo.Contains(keyword, StringComparison.OrdinalIgnoreCase) ||
                x.Reason.Contains(keyword, StringComparison.OrdinalIgnoreCase));
        }

        query = state.SortLabel switch
        {
            "doc" => ApplySort(query, state.SortDirection, x => x.DocumentNo),
            "date" => ApplySort(query, state.SortDirection, x => x.AdjustedAtUtc),
            "reason" => ApplySort(query, state.SortDirection, x => x.Reason),
            "total" => ApplySort(query, state.SortDirection, x => x.TotalAmount),
            "lines" => ApplySort(query, state.SortDirection, x => x.LineCount),
            _ => query.OrderByDescending(x => x.AdjustedAtUtc)
        };

        var totalItems = query.Count();
        var pagedItems = query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToList();

        return Task.FromResult(new TableData<StockAdjustmentListDto>
        {
            TotalItems = totalItems,
            Items = pagedItems
        });
    }

    private static IEnumerable<StockAdjustmentListDto> ApplySort<TKey>(IEnumerable<StockAdjustmentListDto> query, SortDirection direction, Func<StockAdjustmentListDto, TKey> keySelector)
        => direction == SortDirection.Descending ? query.OrderByDescending(keySelector) : query.OrderBy(keySelector);

    private Task OnSearchChanged(string value)
    {
        _searchTerm = value;
        return Task.CompletedTask;
    }

    private static bool IsValidDirection(string? direction)
        => string.Equals(direction, StockAdjustmentDirections.Increase, StringComparison.OrdinalIgnoreCase) ||
           string.Equals(direction, StockAdjustmentDirections.Decrease, StringComparison.OrdinalIgnoreCase);

    private async Task<bool> ConfirmAsync(string title, string content, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.ContentText)] = content,
            [nameof(ConfirmDialog.ButtonText)] = buttonText,
            [nameof(ConfirmDialog.Color)] = color
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(title, parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            CloseOnEscapeKey = true,
            FullWidth = true
        });

        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }
}
