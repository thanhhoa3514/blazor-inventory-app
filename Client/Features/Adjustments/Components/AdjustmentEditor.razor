@namespace MyApp.Client.Features.Adjustments.Components

<AuthorizeView Roles="@AppRoles.AdminOrWarehouseStaff">
    <Authorized>
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Create Adjustment</MudText>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Reason" Variant="Variant.Outlined" Required="true" @bind-Value="Model.Reason" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Note" Variant="Variant.Outlined" @bind-Value="Model.Note" />
                </MudItem>
            </MudGrid>

            <AdjustmentLineEditor Products="Products"
                                  SelectedProductId="SelectedProductId"
                                  SelectedProductIdChanged="SelectedProductIdChanged"
                                  Direction="Direction"
                                  DirectionChanged="DirectionChanged"
                                  Quantity="Quantity"
                                  QuantityChanged="QuantityChanged"
                                  OnAddLine="OnAddLine" />

            @if (Model.Lines.Count > 0)
            {
                <MudTable T="CreateStockAdjustmentLineRequest" Items="Model.Lines" Hover="true" Dense="true" Class="mt-4">
                    <HeaderContent>
                        <MudTh>Product</MudTh>
                        <MudTh>Direction</MudTh>
                        <MudTh>Qty</MudTh>
                        <MudTh Class="text-right">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="line">
                        <MudTd>@GetProductName(line.ProductId)</MudTd>
                        <MudTd>@GetDirectionLabel(line.Direction)</MudTd>
                        <MudTd>@GetSignedQuantity(line)</MudTd>
                        <MudTd Class="text-right">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => OnRemoveLine.InvokeAsync(line))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3">
                    <MudText Typo="Typo.subtitle1">Net Qty Change: @NetQuantityChange</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@IsSubmitting" OnClick="OnSubmit">
                        @(IsSubmitting ? "Submitting..." : "Submit Adjustment")
                    </MudButton>
                </MudStack>
            }
        </MudPaper>
    </Authorized>
</AuthorizeView>

@code {
    [Parameter, EditorRequired] public CreateStockAdjustmentRequest Model { get; set; } = default!;
    [Parameter] public IReadOnlyList<ProductDto> Products { get; set; } = Array.Empty<ProductDto>();
    [Parameter] public int SelectedProductId { get; set; }
    [Parameter] public EventCallback<int> SelectedProductIdChanged { get; set; }
    [Parameter] public string Direction { get; set; } = StockAdjustmentDirections.Increase;
    [Parameter] public EventCallback<string> DirectionChanged { get; set; }
    [Parameter] public int Quantity { get; set; } = 1;
    [Parameter] public EventCallback<int> QuantityChanged { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public EventCallback OnAddLine { get; set; }
    [Parameter] public EventCallback<CreateStockAdjustmentLineRequest> OnRemoveLine { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }

    private int NetQuantityChange => Model.Lines.Sum(GetSignedQuantity);

    private string GetProductName(int productId)
    {
        var product = Products.FirstOrDefault(x => x.Id == productId);
        return product is null ? $"Product #{productId}" : $"{product.Sku} - {product.Name}";
    }

    private static int GetSignedQuantity(CreateStockAdjustmentLineRequest line)
        => string.Equals(line.Direction, StockAdjustmentDirections.Decrease, StringComparison.OrdinalIgnoreCase)
            ? -line.Quantity
            : line.Quantity;

    private static string GetDirectionLabel(string direction)
        => string.Equals(direction, StockAdjustmentDirections.Decrease, StringComparison.OrdinalIgnoreCase) ? "Decrease" : "Increase";
}
