@namespace MyApp.Client.Features.Audit.Components

<MudTable T="AuditLogDto" Items="Items" Hover="true" Dense="true">
    <HeaderContent>
        <MudTh>Entity</MudTh>
        <MudTh>Entity Id</MudTh>
        <MudTh>Action</MudTh>
        <MudTh>Actor</MudTh>
        <MudTh>Occurred</MudTh>
        <MudTh>Summary</MudTh>
        <MudTh Class="text-right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Entity">@context.EntityType</MudTd>
        <MudTd DataLabel="Entity Id">@context.EntityId</MudTd>
        <MudTd DataLabel="Action">@context.Action</MudTd>
        <MudTd DataLabel="Actor">@context.ActorUserName</MudTd>
        <MudTd DataLabel="Occurred">@context.OccurredAtUtc.ToLocalTime().ToString("g")</MudTd>
        <MudTd DataLabel="Summary">@context.Summary</MudTd>
        <MudTd DataLabel="Actions" Class="text-right">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" OnClick="@(() => OnSelect.InvokeAsync(context))">
                View
            </MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Parameter] public IReadOnlyList<AuditLogDto> Items { get; set; } = Array.Empty<AuditLogDto>();
    [Parameter] public EventCallback<AuditLogDto> OnSelect { get; set; }
}
