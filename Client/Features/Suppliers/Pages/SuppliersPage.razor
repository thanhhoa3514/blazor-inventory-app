@page "/suppliers"
@attribute [Authorize]
@inject SupplierApiClient SupplierApiClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Suppliers</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Suppliers</MudText>

@if (!string.IsNullOrWhiteSpace(_serverError))
{
    <ErrorState Message="@_serverError" Class="mb-4" />
}

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.subtitle1">Deactivate for operational pause, soft delete for admin-only removal from lists.</MudText>
    <MudSwitch T="bool" Color="Color.Primary" Value="_showDeleted" ValueChanged="ToggleDeletedAsync">
        Show Deleted
    </MudSwitch>
</MudStack>

@if (!_showDeleted)
{
    <SupplierForm Model="_form" IsSubmitting="_isSubmitting" IsEditing="@_editingId.HasValue" OnSubmit="SaveAsync" />
}

<SupplierTable IsLoading="_isLoading"
               ShowDeleted="_showDeleted"
               SearchTerm="_searchTerm"
               ReloadKey="_tableReloadKey"
               SearchTermChanged="OnSearchChanged"
               ServerData="LoadServerData"
               OnEdit="StartEdit"
               OnDeactivate="DeactivateAsync"
               OnSoftDelete="SoftDeleteAsync"
               OnRestore="RestoreAsync" />

@code {
    private readonly UpdateSupplierRequest _form = new();
    private readonly List<SupplierDto> _items = new();
    private int? _editingId;
    private bool _isLoading = true;
    private bool _isSubmitting;
    private int _tableReloadKey;
    private string? _serverError;
    private bool _showDeleted;
    private string _searchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _serverError = null;

        try
        {
            var result = _showDeleted
                ? await SupplierApiClient.GetDeletedAsync()
                : await SupplierApiClient.GetAllAsync();
            _items.Clear();
            _items.AddRange(result);
        }
        catch (Exception ex)
        {
            _serverError = $"Failed to load suppliers: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            _tableReloadKey++;
        }
    }

    private async Task SaveAsync()
    {
        _isSubmitting = true;
        _serverError = null;

        try
        {
            var result = _editingId.HasValue
                ? await SupplierApiClient.UpdateAsync(_editingId.Value, _form)
                : await SupplierApiClient.CreateAsync(new CreateSupplierRequest
                {
                    Name = _form.Name,
                    Description = _form.Description
                });

            if (!result.Success)
            {
                _serverError = result.ErrorMessage;
                return;
            }

            Snackbar.Add(_editingId.HasValue ? "Supplier updated." : "Supplier created.", Severity.Success);
            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _serverError = $"Save failed: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void StartEdit(SupplierDto item)
    {
        if (_showDeleted)
            return;
        _editingId = item.Id;
        _form.Name = item.Name;
        _form.Description = item.Description;
        _form.IsActive = item.IsActive;
    }

    private async Task SoftDeleteAsync(SupplierDto item)
    {
        _serverError = null;

        var confirmed = await ConfirmAsync(
            title: "Soft Delete Supplier",
            content: $"Soft delete supplier '{item.Name}'? It will be hidden from normal lists but kept for history and can be restored later.",
            buttonText: "Soft Delete",
            color: Color.Error);

        if (!confirmed)
            return;

        try
        {
            var result = await SupplierApiClient.SoftDeleteAsync(item.Id);
            if (!result.Success)
            {
                _serverError = result.ErrorMessage;
                return;
            }

            Snackbar.Add("Supplier soft deleted.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _serverError = $"Soft delete failed: {ex.Message}";
        }
    }

    private async Task RestoreAsync(SupplierDto item)
    {
        _serverError = null;

        var confirmed = await ConfirmAsync(
            title: "Restore Supplier",
            content: $"Restore supplier '{item.Name}'?",
            buttonText: "Restore",
            color: Color.Success);

        if (!confirmed)
            return;

        try
        {
            var result = await SupplierApiClient.RestoreAsync(item.Id);
            if (!result.Success)
            {
                _serverError = result.ErrorMessage;
                return;
            }

            Snackbar.Add("Supplier restored.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _serverError = $"Restore failed: {ex.Message}";
        }
    }

    private async Task DeactivateAsync(SupplierDto item)
    {
        _serverError = null;

        var confirmed = await ConfirmAsync(
            title: "Deactivate Supplier",
            content: $"Deactivate supplier '{item.Name}'? It will no longer be available in receipt selection.",
            buttonText: "Deactivate",
            color: Color.Warning);

        if (!confirmed)
            return;

        try
        {
            var result = await SupplierApiClient.DeactivateAsync(item.Id);
            if (!result.Success)
            {
                _serverError = result.ErrorMessage;
                return;
            }

            if (_editingId == item.Id)
            {
                _form.IsActive = false;
            }

            Snackbar.Add("Supplier deactivated.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _serverError = $"Deactivate failed: {ex.Message}";
        }
    }

    private Task<TableData<SupplierDto>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        IEnumerable<SupplierDto> query = _items;

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var keyword = _searchTerm.Trim();
            query = query.Where(x =>
                x.Name.Contains(keyword, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(x.Description) && x.Description.Contains(keyword, StringComparison.OrdinalIgnoreCase)));
        }

        query = state.SortLabel switch
        {
            "name" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Name) : query.OrderBy(x => x.Name),
            "updated" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.LastUpdatedUtc) : query.OrderBy(x => x.LastUpdatedUtc),
            _ => query.OrderBy(x => x.Name)
        };

        var totalItems = query.Count();
        var pagedItems = query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToList();

        return Task.FromResult(new TableData<SupplierDto>
        {
            TotalItems = totalItems,
            Items = pagedItems
        });
    }

    private Task OnSearchChanged(string value)
    {
        _searchTerm = value;
        return Task.CompletedTask;
    }

    private async Task ToggleDeletedAsync(bool value)
    {
        _showDeleted = value;
        if (_showDeleted)
        {
            ResetForm();
        }
        await LoadAsync();
    }

    private async Task<bool> ConfirmAsync(string title, string content, string buttonText, Color color)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.ContentText)] = content,
            [nameof(ConfirmDialog.ButtonText)] = buttonText,
            [nameof(ConfirmDialog.Color)] = color
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(title, parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            CloseOnEscapeKey = true,
            FullWidth = true
        });

        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }

    private void ResetForm()
    {
        _editingId = null;
        _form.Name = string.Empty;
        _form.Description = string.Empty;
        _form.IsActive = true;
    }
}
