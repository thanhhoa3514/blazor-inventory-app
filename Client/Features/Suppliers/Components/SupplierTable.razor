@namespace MyApp.Client.Features.Suppliers.Components

<MudTable T="SupplierDto" @key="ReloadKey" @ref="_table" ServerData="LoadServerDataAsync" Hover="true" Dense="true" Loading="@IsLoading">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Supplier List</MudText>
        <MudSpacer />
        <MudTextField T="string"
                      Label="Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Value="@SearchTerm"
                      ValueChanged="OnSearchChangedAsync" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="SupplierDto" SortLabel="name">Name</MudTableSortLabel></MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Status</MudTh>
        <MudTh><MudTableSortLabel T="SupplierDto" SortLabel="updated">Updated</MudTableSortLabel></MudTh>
        <MudTh Class="text-right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Description">@context.Description</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                @(context.IsActive ? "Active" : "Inactive")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Updated">@context.LastUpdatedUtc.ToLocalTime().ToString("g")</MudTd>
        <MudTd DataLabel="Actions" Class="text-right">
            <AuthorizeView Roles="@AppRoles.Admin">
                <Authorized Context="authState">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" OnClick="@(() => OnEdit.InvokeAsync(context))">Edit</MudButton>
                    @if (context.IsActive)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" Class="ml-2" OnClick="@(() => OnDeactivate.InvokeAsync(context))">Deactivate</MudButton>
                    }
                </Authorized>
            </AuthorizeView>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="pa-2">No suppliers found.</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new[] { 5, 10, 25, 50 }" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<SupplierDto>? _table;

    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string SearchTerm { get; set; } = string.Empty;
    [Parameter] public int ReloadKey { get; set; }
    [Parameter] public EventCallback<string> SearchTermChanged { get; set; }
    [Parameter, EditorRequired] public Func<TableState, CancellationToken, Task<TableData<SupplierDto>>> ServerData { get; set; } = default!;
    [Parameter] public EventCallback<SupplierDto> OnEdit { get; set; }
    [Parameter] public EventCallback<SupplierDto> OnDeactivate { get; set; }

    private Task<TableData<SupplierDto>> LoadServerDataAsync(TableState state, CancellationToken cancellationToken)
        => ServerData.Invoke(state, cancellationToken);

    private async Task OnSearchChangedAsync(string value)
    {
        await SearchTermChanged.InvokeAsync(value);
        if (_table is not null)
        {
            await _table.ReloadServerData();
        }
    }
}
