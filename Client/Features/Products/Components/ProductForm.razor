@namespace MyApp.Client.Features.Products.Components

<AuthorizeView Roles="@AppRoles.Admin">
    <Authorized>
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudForm @ref="_formRef" Model="@Model">
                <MudGrid>
                    <MudItem xs="12" md="2">
                        <MudTextField T="string" Label="SKU" Variant="Variant.Outlined" @bind-Value="Model.Sku"
                                      For="@(() => Model.Sku)" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField T="string" Label="Name" Variant="Variant.Outlined" @bind-Value="Model.Name"
                                      For="@(() => Model.Name)" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField T="string" Label="Description" Variant="Variant.Outlined" @bind-Value="Model.Description"
                                      For="@(() => Model.Description)" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudSelect T="int" Label="Category" Variant="Variant.Outlined" @bind-Value="Model.CategoryId"
                                   For="@(() => Model.CategoryId)">
                            <MudSelectItem T="int" Value="0">Select category</MudSelectItem>
                            @foreach (var category in Categories)
                            {
                                <MudSelectItem T="int" Value="@category.Id">@category.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" md="1">
                        <MudNumericField T="int" Label="Reorder" Variant="Variant.Outlined" Min="0"
                                         @bind-Value="Model.ReorderLevel" For="@(() => Model.ReorderLevel)" />
                    </MudItem>
                    <MudItem xs="6" md="1">
                        <MudNumericField T="int" Label="Target" Variant="Variant.Outlined" Min="0"
                                         @bind-Value="Model.TargetStockLevel" For="@(() => Model.TargetStockLevel)" />
                    </MudItem>
                    <MudItem xs="12" md="1" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="@IsSubmitting"
                                   OnClick="SubmitAsync">
                            @(IsSubmitting ? "..." : (IsEditing ? "Update" : "Create"))
                        </MudButton>
                    </MudItem>
                    @if (IsEditing)
                    {
                        <MudItem xs="12">
                            <MudSwitch T="bool" Color="Color.Primary" @bind-Value="Model.IsActive">Active product</MudSwitch>
                        </MudItem>
                    }
                </MudGrid>
            </MudForm>
        </MudPaper>
    </Authorized>
</AuthorizeView>

@code {
    private MudForm? _formRef;

    [Parameter, EditorRequired] public ProductEditorModel Model { get; set; } = default!;
    [Parameter] public IReadOnlyList<CategoryDto> Categories { get; set; } = Array.Empty<CategoryDto>();
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public bool IsEditing { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }

    private async Task SubmitAsync()
    {
        if (_formRef is null)
        {
            return;
        }

        await _formRef.Validate();
        if (_formRef.IsValid)
        {
            await OnSubmit.InvokeAsync();
        }
    }
}
